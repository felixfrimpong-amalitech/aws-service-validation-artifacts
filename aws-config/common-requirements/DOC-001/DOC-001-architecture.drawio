        <mxCell id="rule_desc1" value="1. EBS GP3: Detect gp2 volumes → recommend gp3 (20% cost savings)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="118" y="1485" width="460" height="30" as="geometry" />
