        <mxCell id="notes_title" value="Architecture Characteristics:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="560" y="1450" width="240" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note1" value="• High Availability: AWS managed services with multi-AZ by default" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="560" y="1470" width="480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="• Automatic Scaling: Serverless Lambda, StackSets auto-deploy to new accounts" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="560" y="1500" width="410" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note3" value="• Evaluation Triggers: Config change events + periodic (6-hour intervals)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="560" y="1530" width="520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note4" value="• Bootstrapless: No CDK bootstrap, inline Lambda code, service-managed StackSets" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="560" y="1560" width="430" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note5" value="• Security: TLS enforced, SSE-S3 encryption, least-privilege IAM" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="560" y="1590" width="480" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note6" value="• Region Scope: Single-region deployment (multi-region via separate stacks)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="560" y="1620" width="390" height="30" as="geometry" />
        </mxCell>
        <mxCell id="rules_title" value="Cost Optimization Rules:" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="115" y="1460" width="240" height="30" as="geometry" />
